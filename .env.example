# Exemplo de configuração de ambiente da MMA Analytics Platform.
# Copie para `.env` na raiz (`cp .env.example .env`) e preencha os segredos.
# O `.env` é lido por pydantic-settings (mma_analytics/settings.py) e NÃO é
# versionado (está no .gitignore). Este arquivo é o contrato das variáveis.

# --- Aplicação ---
# local | test  (em `test` o banco efetivo vira ufc_bum_test, isolando a suíte)
APP_ENV=local

# --- Banco (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ufc_databum
DB_USER=devuser
# Segredo real vem daqui; o default de dev (devpass) é só do compose compartilhado.
DB_PASSWORD=devpass

# --- Cito API (ingestão incremental, M1) ---
# Token do free tier (500 req/mês). Vazio é aceitável no modo fixture (caminho de
# teste, não consome a quota); para rodar contra a API real, preencha o token.
CITO_API_TOKEN=
CITO_BASE_URL=https://mmaapi.dev
# Teto de chamadas à Cito por execução do job. A flag CLI --call-budget vence isto,
# que vence o default de 500. Descomente para sobrescrever.
# CITO_CALL_BUDGET=500
