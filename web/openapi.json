    "/api/v1/head-to-head": {
      "get": {
        "tags": [
          "head-to-head"
        ],
        "summary": "Head To Head",
        "description": "Confrontos diretos entre dois lutadores em ordem cronol\u00f3gica.\n\nValida no router: ``a == b`` -> 422 (lutadores devem ser distintos); ``a`` ou\n``b`` inexistente -> 404. Ambos existentes sem confronto direto retorna 200\ncom lista vazia -- distinto do 404. A leitura sai do selector (router fino).",
        "operationId": "head_to_head_api_v1_head_to_head_get",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "Id do primeiro lutador",
              "title": "A"
            },
            "description": "Id do primeiro lutador"
          },
          {
            "name": "b",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "Id do segundo lutador",
              "title": "B"
            },
            "description": "Id do segundo lutador"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeadToHeadOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
